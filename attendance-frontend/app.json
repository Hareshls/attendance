{
  "expo": {
    "name": "FieldVerify",
    "slug": "attendance-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "backgroundColor": "#0A0A0F",
    "sdkVersion": "54.0.0",
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FieldVerify to access your camera for face verification."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow FieldVerify to access your location for attendance."
        }
      ],
      "expo-sqlite",
      "expo-secure-store"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fieldverify.attendance"
    },
    "android": {
      "package": "com.fieldverify.attendance",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    }
  }
}
